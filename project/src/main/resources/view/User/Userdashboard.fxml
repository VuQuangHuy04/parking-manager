<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.controller.UserController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding:10; -fx-background-color:#2c3e50;">
            <Label style="-fx-text-fill:white; -fx-font-size:18; -fx-font-weight:bold;" text="HỆ THỐNG BÃI GIỮ XE" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="usernameLabel" style="-fx-text-fill:white;" text="Xin chào" />
            <Button onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" text="Đăng xuất" />
        </HBox>
    </top>

    <left>
        <VBox prefWidth="210.0" spacing="10" style="-fx-padding:15; -fx-background-color:#ecf0f1;">

            <VBox fx:id="userMenuBox" managed="false" spacing="10" visible="false">
                <Label style="-fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="MENU NGƯỜI DÙNG" />
                <Button onAction="#openParkingLots" prefWidth="180" text="🅿 Chọn bãi xe" />
                <Button onAction="#openHistory" prefWidth="180" text="📜 Lịch sử gửi xe" />
                <Button onAction="#openInformation" prefWidth="180" text="👤 Thông tin cá nhân" />
            </VBox>

            <VBox fx:id="adminMenuBox" managed="false" spacing="10" visible="false">
                <Label style="-fx-text-fill: #7f8c8d; -fx-font-weight: bold;" text="MENU QUẢN TRỊ" />
                <Button onAction="#openAdminControl" prefWidth="180" text="🛠 Quản lý bãi xe" />
                <Button onAction="#openUserManagement" prefWidth="180" text="👥 Quản lý người dùng" />
                <Button onAction="#openSystemReport" prefWidth="180" text="📊 Báo cáo hệ thống" />
            </VBox>

        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentPane" style="-fx-background-color: white; -fx-padding: 20;">
            <Label text="Vui lòng chọn một tính năng để bắt đầu" textFill="#95a5a6" />
        </StackPane>
    </center>

</BorderPane>